{
	"name": "git-hooks",
	"displayName": "git_hooks",
	"description": "Integrating git hooks to vscode",
	"version": "0.0.1",
	"publisher": "lakshmikanthayyadevara",
	"engines": {
		"vscode": "^1.64.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"menus": {
			"view/title": [
				{
					"command": "git-hooks.reloadHooks",
					"when": "view == git_hooks_view",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "git-hooks.openHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				},
				{
					"command": "git-hooks.runHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				},
				{
					"command": "git-hooks.toggleHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "git_hooks",
					"title": "Git Hooks",
					"icon": "./src/git_hooks_icon.svg"
				}
			]
		},
		"views": {
			"git_hooks": [
				{
					"id": "git_hooks_view",
					"name": "Git Hooks",
					"when": "workSpaceHasGit"
				}
			]
		},
		"commands": [
			{
				"command": "git-hooks.openHook",
				"title": "Open Hook",
				"icon": "$(edit)"
			},
			{
				"command": "git-hooks.runHook",
				"title": "Run Hook",
				"icon": "$(debug-start)"
			},
			{
				"command": "git-hooks.toggleHook",
				"title": "Toggle Hook",
				"icon": "$(pin)"
			},
			{
				"command": "git-hooks.reloadHooks",
				"title": "Reload Hooks",
				"icon": "$(timeline-refresh)"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.64.0",
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.0.0",
		"@types/node": "14.x",
		"@typescript-eslint/eslint-plugin": "^5.9.1",
		"@typescript-eslint/parser": "^5.9.1",
		"eslint": "^8.6.0",
		"glob": "^7.2.0",
		"mocha": "^9.1.3",
		"typescript": "^4.5.4",
		"@vscode/test-electron": "^2.0.3"
	}
}
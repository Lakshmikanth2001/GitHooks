{
	"name": "githooks",
	"displayName": "GitHooks -- Simple VS-Code UI for git hooks",
	"description": "Integrating git hooks to vscode UI",
	"version": "0.0.2",
	"license": "SEE LICENSE IN LICENSE",
	"publisher": "lakshmikanthayyadevara",
	"main": "./out/extension.js",
	"icon": "assets/icon.png",
	"engines": {
		"vscode": "^1.64.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Lakshmikanth2001/GitHooks"
	},
	"bugs": {
		"email": "lakshmikanth2001@gmail.com",
		"url": "https://github.com/Lakshmikanth2001/GitHooks/issues"
	},
	"author": {
		"name": "Lakshmikanth Ayyadevara",
		"email": "lakshmikanth2001@gmail.com"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"workspaceContains:.git"
	],
	"keywords": [
		"git",
		"hooks",
		"githooks",
		"gitHooks",
		"git_hooks",
		"git hooks",
		"Git Hooks",
		"Git hooks"
	],
	"contributes": {
		"menus": {
			"view/title": [
				{
					"command": "git-hooks.reloadHooks",
					"when": "view == git_hooks_view",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "git-hooks.openHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				},
				{
					"command": "git-hooks.runHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				},
				{
					"command": "git-hooks.toggleHook",
					"when": "view == git_hooks_view && viewItem == label",
					"group": "inline"
				},
				{
					"command": "git-hooks.openHook",
					"when": "view == git_hooks_view && viewItem == label"
				},
				{
					"command": "git-hooks.runHook",
					"when": "view == git_hooks_view && viewItem == label"
				},
				{
					"command": "git-hooks.toggleHook",
					"when": "view == git_hooks_view && viewItem == label"
				},
				{
					"command": "git-hooks.hookDescription",
					"when": "view == git_hooks_view && viewItem == label"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "git_hooks",
					"title": "Git Hooks",
					"icon": "assets/git_hooks_icon.svg"
				}
			]
		},
		"views": {
			"git_hooks": [
				{
					"id": "git_hooks_view",
					"name": "Git Hooks",
					"when": "workSpaceHasGit"
				}
			]
		},
		"commands": [
			{
				"command": "git-hooks.openHook",
				"title": "Open Hook",
				"icon": "$(edit)"
			},
			{
				"command": "git-hooks.runHook",
				"title": "Run Hook",
				"icon": "$(debug-start)"
			},
			{
				"command": "git-hooks.toggleHook",
				"title": "Toggle Hook",
				"icon": "$(pin)"
			},
			{
				"command": "git-hooks.reloadHooks",
				"title": "Reload Hooks",
				"icon": "$(timeline-refresh)"
			},
			{
				"command": "git-hooks.hookDescription",
				"title": "Hook Description"
			}
		],
		"configuration":{
			"type":"object",
			"title": "GitHooks Configuration",
			"properties": {
				"GitHooks.supportedLanguages":{
					"type":"array",
					"default":["python", "bash", "perl"],
					"description": "List of supported languages for git hooks"
				}
			}
		},
		"snippets": [
			{
				"language": "python",
				"path": "./src/snippets/python.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.64.0",
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.0.0",
		"@types/node": "14.x",
		"@typescript-eslint/eslint-plugin": "^5.9.1",
		"@typescript-eslint/parser": "^5.9.1",
		"eslint": "^8.6.0",
		"glob": "^7.2.0",
		"mocha": "^9.1.3",
		"typescript": "^4.5.4",
		"@vscode/test-electron": "^2.0.3"
	}
}